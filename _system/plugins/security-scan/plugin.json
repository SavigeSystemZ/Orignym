{
  "name": "security-scan",
  "version": "1.1.0",
  "description": "Integrated SAST/DAST security scanning for AIAST repos.",
  "aiast_min_version": "1.21.0",
  "hooks": ["security.scan", "security.audit", "validation.report"],
  "capabilities": ["security-scanner", "audit-reporter"],
  "owned_paths": ["_system/plugins/security-scan/"],
  "requires": ["semgrep", "nmap"],
  "enabled": true
}
